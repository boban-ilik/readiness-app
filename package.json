{
  "name": "readiness",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "sed -i '' 's/objectVersion = 70/objectVersion = 60/' ios/Readiness.xcodeproj/project.pbxproj && expo run:ios --device",
    "ios:sim": "sed -i '' 's/objectVersion = 70/objectVersion = 60/' ios/Readiness.xcodeproj/project.pbxproj && expo run:ios --simulator 'iPhone 16'",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
