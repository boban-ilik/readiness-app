    "@supabase/supabase-js": "^2.43.4",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.9",
    "expo-haptics": "~13.0.1",
    "expo-image-picker": "~15.0.7",
    "expo-linking": "~6.3.1",
