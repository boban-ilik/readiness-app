# Supabase — get these from your project dashboard at app.supabase.com
# Settings → API → Project URL and Project API keys (anon/public key)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Claude API key — stored as a Supabase secret, NOT in this file.
# Run once after deploying the edge function:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# See supabase/functions/ai-insight/README.md for full setup instructions.
